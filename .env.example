# Скопируйте в .env и задайте свои значения:
# cp .env.example .env

# Домен сайта (Caddy + автоматический HTTPS)
# Для продакшена:  map.example.com
# Для теста по IP:  :80
SITE_ADDRESS=map.example.com

# ОБЯЗАТЕЛЬНО для HTTPS: настоящий email (не example.com!)
ACME_EMAIL=

# Пароль для редактирования статусов на карте (только вы)
ADMIN_PASSWORD=your-secure-password-here

# Секрет для сессии (случайная строка, минимум 32 символа)
SESSION_SECRET=replace-with-long-random-string

# Telegram-уведомления о новых сообщениях (необязательно)
# Создайте бота через @BotFather, узнайте chat_id через @userinfobot или @getidsbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Топик в группе с «Темами» (Forum) для всех уведомлений с сайта.
# ID темы = message_thread_id (узнать через @getidsbot). Необязательно.
TELEGRAM_TOPIC_ID=

# Прокси для запросов к Telegram API (если api.telegram.org недоступен напрямую)
# HTTP/HTTPS:  http://user:pass@host:port
# SOCKS5:      socks5://user:pass@host:port
TELEGRAM_PROXY=

# Автоматическая выгрузка БД в Telegram (часы, 0 = только вручную из админки)
# TELEGRAM_BACKUP_INTERVAL_HOURS=24
